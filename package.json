{
  "name": "applog",
  "version": "1.0.0",
  "description": "a simple blog",
  "scripts": {
    "fe": "pnpm --filter @applog/frontend run dev",
    "be": "pnpm --filter @applog/backend run dev",
    "dev": "turbo run dev",
    "build:fe": "turbo run build --filter=@applog/frontend",
    "build:be": "turbo run build --filter=@applog/backend",
    "build": "turbo run build",
    "c": "git-cz"
  },
  "private": true,
  "keywords": [],
  "author": "youranreus (https://mitsuha.space)",
  "license": "ISC",
  "devDependencies": {
    "commitizen": "^4.3.0",
    "cz-customizable": "^7.0.0",
    "turbo": "^2.8.11"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-customizable"
    }
  },
  "packageManager": "pnpm@10.7.0+sha512.6b865ad4b62a1d9842b61d674a393903b871d9244954f652b8842c2b553c72176b278f64c463e52d40fff8aba385c235c8c9ecf5cc7de4fd78b8bb6d49633ab6"
}
