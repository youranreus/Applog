### ❌ 错误示例（逻辑过多）
```vue
<script setup lang="ts">
// ❌ 错误：在组件中编写过多业务逻辑
const fetchUserData = async () => {
  // 不应该在这里写 API 调用逻辑
  const response = await fetch(`/api/users/${userId}`)
  const data = await response.json()
  // ... 更多业务逻辑
}
</script>
```

### ✅ 正确示例（逻辑分离）
```vue
<script setup lang="ts">
// ✅ 正确：使用 hook 处理业务逻辑
import { useUser } from '@/hooks/useUser'

const { user, loading, error } = useUser(props.userId)
</script>
```

## 组合式函数 (Composables / Hooks)

### 分类说明
项目中的 hooks 分为两类：

**1. 公共 Hooks（@hooks）**
- **必须无业务属性**，保持通用性
- 可在任何业务场景中复用
- 例如：`useRequest`, `useLocalStorage`, `useDebounce`, `useThrottle`
- 这些 hooks 不应该包含任何业务逻辑

**2. 业务 Hooks（可选，建议放在业务模块目录）**
- 包含特定业务逻辑
- 通常组合使用多个公共 hooks 和 stores
- 例如：可以在 `pages/user/hooks/useUserList.ts` 中创建 `useUserList`

### 公共 Hook 示例
```typescript
/**
 * 通用请求 Hook（无业务属性）
 * @param url - 请求地址
 * @param options - 请求选项
 * @returns 请求状态和数据
 * 
 * 逻辑说明：
 * 1. 管理请求的加载状态
 * 2. 处理请求错误
 * 3. 返回响应数据
 */
export function useRequest<T>(
  url: string,
  options?: RequestInit,
): {
  loading: Ref<boolean>
  error: Ref<Error | null>
  data: Ref<T | null>
  execute: () => Promise<void>
} {
  const loading = ref(false)
  const error = ref<Error | null>(null)
  const data = ref<T | null>(null)

  const execute = async () => {
    loading.value = true
    error.value = null
    
    try {
      const response = await fetch(url, options)
      if (!response.ok) {
        throw new Error(`HTTP error! status: ${response.status}`)
      }
      data.value = await response.json()
    } catch (e) {
      error.value = e instanceof Error ? e : new Error('Unknown error')
    } finally {
      loading.value = false
    }
  }

  return { loading, error, data, execute }
}
```

### 业务 Hook 示例（可在页面目录中）
```typescript
/**
 * 用户列表 Hook（包含业务逻辑）
 * @param query - 查询条件
 * @returns 用户列表相关状态和方法
 */
export function useUserList(query: IUserQuery) {
  // 使用公共 hook
  const { loading, error, data, execute } = useRequest<IUser[]>(
    `/api/users?keyword=${query.keyword}`,
  )
  
  // 业务逻辑
  const users = computed(() => data.value || [])
  const hasUsers = computed(() => users.value.length > 0)
  
  // 业务方法
  const refresh = () => {
    execute()
  }

  return { loading, error, users, hasUsers, refresh }
}
```

### Hook 编写规范
- 使用 `use` 前缀命名（如 `useUser`, `useAuth`, `useRequest`）
- 提供完整的 TypeScript 类型定义
- **必须添加 JSDoc 注释**：标注参数、返回值和逻辑说明
- 保持函数职责单一
- 公共 hooks 必须无业务属性

## 类型定义

### 类型文件组织
- 在 `@types` 目录下按模块组织类型文件
- 文件命名：kebab-case（如 `user.types.ts`, `api.types.ts`）

### 类型定义规范
```typescript
// types/user.types.ts

// Interface 使用 I 前缀
export interface IUser {
  id: string
  userName: string
  email: string
  createdAt: string
}

export interface IUserResponse {
  data: IUser
  message: string
}

// Type 类型别名使用 PascalCase
export type UserRole = 'admin' | 'user'
export type UserStatus = 'active' | 'inactive'

// 常量对象
export const USER_ROLES = {
  ADMIN: 'admin',
  USER: 'user',
} as const
```

### 组件 Props 类型
```typescript
// ✅ 正确：使用 interface 定义 props
interface IUserCardProps {
  user: IUser
  showEmail?: boolean
  onEdit?: (id: string) => void
}

const props = defineProps<IUserCardProps>()

// ✅ 正确：使用 interface 定义 emits
interface IUserCardEmits {
  (e: 'edit', id: string): void
  (e: 'delete', id: string): void
}

const emit = defineEmits<IUserCardEmits>()
```

## 分层开发理念

### 三层架构
项目严格遵循三层架构：

**1. 视图层（View Layer）**
- **位置**：`@pages` 目录下的 `.vue` 文件
- **职责**：专注于 UI 渲染和用户交互
- **原则**：
  - 组件保持简洁，只处理视图相关逻辑
  - 不直接调用 API
  - 不包含复杂业务逻辑
  - 通过 hooks 或 stores 获取数据和操作方法

**2. 数据层（Data Layer）**
- **位置**：`@stores` 目录
- **职责**：管理应用状态和业务逻辑
- **原则**：
  - 包含业务状态管理
  - 包含业务操作方法
  - API 调用封装在 stores 中

**3. 接口层（API Layer）**
- **位置**：可在 `@utils/api.ts` 或 stores 中直接封装
- **职责**：封装 API 请求
- **原则**：
  - 统一处理请求和响应
  - 统一错误处理
  - 类型安全

### 分层开发示例

**视图层（UserList.vue）**
```vue
<script setup lang="ts">
import { useUserList } from './hooks/useUserList'
import { useUserStore } from '@/stores/user-store'

// 视图层只负责组合 hooks 和渲染
const query = ref({ keyword: '' })
const { users, loading, refresh } = useUserList(query)
</script>

<template>
  <div>
    <input v-model="query.keyword" />
    <button @click="refresh">刷新</button>
    <ul v-if="!loading">
      <li v-for="user in users" :key="user.id">
        {{ user.userName }}
      </li>
    </ul>
  </div>
</template>
```

**数据层（user-store.ts）**
```typescript
// stores/user-store.ts
export const useUserStore = defineStore('user', () => {
  const users = ref<IUser[]>([])
  const loading = ref(false)

  /**
   * 获取用户列表
   * @param query - 查询条件
   * @returns 用户列表
   */
  async function fetchUsers(query: IUserQuery): Promise<IUser[]> {
    loading.value = true
    try {
      // API 调用封装在 store 中
      const response = await api.get<IUserResponse[]>('/api/users', { params: query })
      users.value = response.data
      return users.value
    } catch (error) {
      console.error('获取用户列表失败', error)
      throw error
    } finally {
      loading.value = false
    }
  }

  return { users, loading, fetchUsers }
})
```

## 代码复用与分割

### 代码复用原则
1. **提取公共逻辑**：
   - 通用逻辑提取到 `@hooks`（无业务属性）
   - 业务逻辑提取到 `@stores` 或业务 hooks
   - 工具函数提取到 `@utils`

2. **合理分割代码**：
   - 单个组件不超过 300 行
   - 单个函数不超过 150 行
   - 单个 hook 职责单一

3. **代码组织**：
   - 按功能模块组织代码
   - 使用 barrel exports（index.ts）统一导出
   - 避免循环依赖

## Store 使用规范

### Store 组织
- 使用 Pinia 进行状态管理
- 按功能模块划分 store
- Store 文件命名：kebab-case（如 `user-store.ts`, `post-store.ts`）

### Store 结构
```typescript
import { defineStore } from 'pinia'
import type { IUser, IUserQuery } from '@/types/user.types'
import { api } from '@/utils/api'

/**
 * 用户 Store
 * 管理用户相关的状态和业务逻辑
 */
export const useUserStore = defineStore('user', () => {
  // State
  const user = ref<IUser | null>(null)
  const users = ref<IUser[]>([])
  const loading = ref(false)

  // Getters
  const isLoggedIn = computed(() => user.value !== null)
  const userName = computed(() => user.value?.userName || '')

  // Actions
  /**
   * 获取当前用户信息
   * @returns 用户信息
   */
  async function fetchCurrentUser(): Promise<IUser> {
    loading.value = true
    try {
      const response = await api.get<IUser>('/api/user/me')
      user.value = response.data
      return user.value
    } catch (error) {
      console.error('获取用户信息失败', error)
      throw error
    } finally {
      loading.value = false
    }
  }

  /**
   * 获取用户列表
   * @param query - 查询条件
   */
  async function fetchUsers(query: IUserQuery): Promise<void> {
    loading.value = true
    try {
      const response = await api.get<IUser[]>('/api/users', { params: query })
      users.value = response.data
    } catch (error) {
      console.error('获取用户列表失败', error)
      throw error
    } finally {
      loading.value = false
    }
  }

  /**
   * 清除用户状态
   */
  function clearUser(): void {
    user.value = null
    users.value = []
  }

  return {
    // State
    user,
    users,
    loading,
    // Getters
    isLoggedIn,
    userName,
    // Actions
    fetchCurrentUser,
    fetchUsers,
    clearUser,
  }
})
```

## 路由配置规范

### 路由文件组织
- 路由配置在 `@router` 目录
- 支持路由懒加载
- 路由命名使用 camelCase

### 路由示例
```typescript
import { createRouter, createWebHistory } from 'vue-router'
import type { RouteRecordRaw } from 'vue-router'

const routes: RouteRecordRaw[] = [
  {
    path: '/',
    name: 'home',
    component: () => import('@/pages/Home.vue'),
  },
  {
    path: '/users',
    name: 'userList',
    component: () => import('@/pages/user/UserList.vue'),
  },
  {
    path: '/users/:id',
    name: 'userDetail',
    component: () => import('@/pages/user/UserDetail.vue'),
    props: true,
  },
]

const router = createRouter({
  history: createWebHistory(import.meta.env.BASE_URL),
  routes,
})

export default router
```

## 工具函数规范

### 工具函数组织
- 在 `@utils` 目录下按功能组织工具文件
- 文件命名：kebab-case（如 `date-utils.ts`, `format-utils.ts`）
- 工具函数应该是纯函数（无副作用）

### 工具函数示例
```typescript
/**
 * 格式化日期
 * @param date - 日期对象或时间戳
 * @param format - 格式字符串
 * @returns 格式化后的日期字符串
 */
export function formatDate(
  date: Date | number,
  format: string = 'YYYY-MM-DD',
): string {
  const d = typeof date === 'number' ? new Date(date) : date
  // 格式化逻辑...
  return formatted
}

/**
 * 防抖函数
 * @param fn - 要防抖的函数
 * @param delay - 延迟时间（毫秒）
 * @returns 防抖后的函数
 */
export function debounce<T extends (...args: unknown[]) => unknown>(
  fn: T,
  delay: number = 300,
): (...args: Parameters<T>) => void {
  let timer: ReturnType<typeof setTimeout>
  return function (...args: Parameters<T>) {
    clearTimeout(timer)
    timer = setTimeout(() => fn(...args), delay)
  }
}
```

## 前端开发重点

### 组件编写
- 使用 `<script setup lang="ts">` 语法
- 使用 Composition API
- 组件应专注于视图渲染，复杂逻辑提取到 hooks 或 stores
- 合理选择组件放置位置：
  - 通用组件放在 `@components`
  - 业务组件放在对应页面目录

### Shadcn-vue 使用
- 组件通过 `pnpm dlx shadcn-vue@latest add <component>` 添加
- 组件统一放在 `@components/ui` 目录
- 可以直接修改组件代码进行定制

### Hooks 分类
- **公共 Hooks（@hooks）**: 必须无业务属性，保持通用性
- **业务 Hooks**: 可在页面目录中创建，包含特定业务逻辑

### Store 使用
- 使用 Pinia 进行状态管理
- Store 文件命名：kebab-case（如 `user-store.ts`）
- API 调用封装在 stores 中

### 类型定义
- Interface 使用 `I` 前缀 + PascalCase（如 `IUser`）
- Type 使用 PascalCase（如 `UserRole`）
- 文件命名：kebab-case（如 `user.types.ts`）

### 代码规范
- 所有函数必须添加 JSDoc 注释
- 单个组件不超过 300 行
- 单个函数不超过 150 行
- 使用 `async/await`，禁止混用 `.then()`

### 分层开发
- **视图层**: 专注于 UI 渲染，不直接调用 API
- **数据层**: Store 管理状态和业务逻辑
- **接口层**: API 请求封装
